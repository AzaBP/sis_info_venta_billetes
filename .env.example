# Ejemplo de variables de entorno para configuración SMTP
# Rellena con tus datos reales y añade estas variables en tu entorno o en Docker.

SMTP_HOST=smtp.tudominio.com
SMTP_USER=no-reply@tudominio.com
SMTP_PASS=tu_contraseña_o_api_key
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_FROM=no-reply@tudominio.com
SMTP_FROM_NAME="SISTEMA BILLETES"
